[orphan]
.claude/

    [orphan]
    .claude/settings.local.json

src/
    -> src/main.rs : crate entrypoint and CLI wiring; paired context: crate root entrypoint

    src/commands/
        -> src/commands/mod.rs : subcommand module registry

        src/commands/mod.rs
            -- src/main.rs : imported by CLI for command dispatch; paired context: CLI command wiring and dispatch
            -> src/commands/init.rs : init command module
            -> src/commands/update.rs : update command module
            -> src/commands/status.rs : status command module
            -> src/commands/inspect.rs : inspect command module
            -> src/commands/intentionalize_orphans.rs : mark-orphans command module
            -> src/commands/list.rs : list command module
            -> src/commands/edit.rs : edit command module
            -> src/commands/view.rs : view and setup command module
            -> src/commands/open.rs : static HTML export/open command module

        src/commands/edit.rs
            -> src/tangle.rs : resolves graph/config paths; paired context: graph/config path lookup
            -> src/parser/config.rs : resolves preferred editor; paired context: configured editor resolution

        src/commands/init.rs
            -> src/scanner/tree.rs : scans repository tree for bootstrap nodes; paired context: bootstrap scan
            -> src/parser/graph.rs : serializes initial graph document; paired context: initial graph generation
            -> src/parser/config.rs : writes default config; paired context: default config generation
            -> src/tangle.rs : resolves tangle directory paths; paired context: tangle path helpers

        src/commands/inspect.rs
            -> src/parser/graph.rs : parses graph document for queries; paired context: query source document
            -> src/graph/model.rs : traverses graph/edge model; paired context: query traversal over graph model
            -> src/tangle.rs : finds active repo root; paired context: repo root lookup

        src/commands/intentionalize_orphans.rs
            -> src/parser/graph.rs : marks unattended isolated nodes; paired context: orphan marker updates
            -> src/tangle.rs : locates graph file; paired context: graph path lookup

        src/commands/list.rs
            -> src/parser/graph.rs : parses graph for listing; paired context: listing source parse
            -> src/graph/model.rs : iterates edge model in graph order; paired context: edge listing over model
            -> src/tangle.rs : locates graph file; paired context: graph path lookup

        src/commands/open.rs
            <- src/main.rs : dispatched by CLI to export map.html and open it in a browser

        src/commands/status.rs
            -> src/commands/update.rs : reuses update preview logic
            -> src/scanner/tree.rs : scans filesystem state; paired context: status scan
            -> src/scanner/diff.rs : computes filesystem-vs-graph differences; paired context: status diffing
            -> src/parser/config.rs : reads status warning settings; paired context: reads status flags
            -> src/parser/graph.rs : parses tags and graph content; paired context: tag/query parse
            -> src/graph/model.rs : traverses edge state; paired context: drift checks over model
            -> src/tangle.rs : locates graph/config files; paired context: graph/config path lookup

        src/commands/update.rs
            -> src/scanner/tree.rs : scans current filesystem nodes; paired context: reconciliation scan
            -> src/scanner/diff.rs : computes additions and removals; paired context: update reconciliation diffing
            -> src/parser/config.rs : reads reconcile behavior; paired context: reads update behavior
            -> src/parser/graph.rs : mutates graph document; paired context: reconcile mutations
            -> src/graph/model.rs : applies graph-level mutations; paired context: mutation target model
            -> src/tangle.rs : resolves graph/config file paths; paired context: graph/config path lookup

        src/commands/view.rs
            -> src/tui/canvas.rs : launches interactive TUI; paired context: launched by view/setup commands

    src/graph/
        -> src/graph/mod.rs : graph namespace module

        src/graph/mod.rs
            -> src/graph/model.rs : exports graph data model
            <- src/main.rs : linked from crate root; paired context: graph module linkage

        src/graph/model.rs
            <- src/parser/graph.rs : parser round-trips into model; paired context: parser <-> model conversion
            <- src/tui/canvas.rs : view/edit runtime model; paired context: in-memory graph state
            <- src/tui/render.rs : rendering relation kinds/icons; paired context: EdgeKind drives relation rendering

    src/parser/
        -> src/parser/mod.rs : parser namespace module

        src/parser/config.rs
            <- src/tui/canvas.rs : runtime settings state; paired context: reads/writes config values
            <- src/tui/settings.rs : setup panel serialization; paired context: serializes setup toggles into config
            <- src/parser/mod.rs : config parser export; paired context: exports config parser

        src/parser/graph.rs
            <- src/tui/canvas.rs : view writes and normalization; paired context: persists graph edits
            <- src/parser/mod.rs : graph parser export; paired context: exports graph parser

        src/parser/mod.rs
            <- src/main.rs : linked from crate root; paired context: parser module linkage

    src/scanner/
        -> src/scanner/mod.rs : scanner namespace module

        src/scanner/diff.rs
            -> src/graph/model.rs : diff against graph model
            <- src/scanner/mod.rs : diff scanner export; paired context: exports diff scanner

        src/scanner/mod.rs
            -> src/scanner/tree.rs : exports tree scanner; paired context: tree scanner export
            <- src/main.rs : linked from crate root; paired context: scanner module linkage

        src/scanner/tree.rs
            <- .gitignore : ignore rules affect scan output; paired context: ignore patterns influence scanning

    src/tui/
        -> src/tui/mod.rs : tui namespace module

        src/tui/canvas.rs
            -> src/tui/input.rs : maps keys to actions; paired context: action mapping consumed by state machine
            -> src/tui/render.rs : draws tree/details/status/help; paired context: receives render data from app state
            -> src/tui/settings.rs : setup popup behavior; paired context: setup panel host and event loop
            -> src/tangle.rs : resolves repo graph/config paths; paired context: view persist path lookup

        src/tui/input.rs

        src/tui/mod.rs
            -> src/tui/canvas.rs : exports canvas module
            -> src/tui/input.rs : exports input module
            -> src/tui/render.rs : exports render module
            -> src/tui/settings.rs : exports settings module
            <- src/main.rs : linked from crate root; paired context: tui module linkage

        src/tui/render.rs

        src/tui/settings.rs

    src/main.rs
        -> src/tangle.rs : repo root and tangle path helpers; paired context: root discovery plumbing
        <- Cargo.toml : binary target points here; paired context: binary entrypoint declaration

    src/tangle.rs

.gitignore
    <- README.md : documented repo hygiene

[orphan]
Cargo.lock

Cargo.toml

[orphan]
LICENSE

README.md
    -> src/tui/canvas.rs : describes TUI workflows and behaviors
    -> src/tui/input.rs : documents active keymap
    -> src/parser/config.rs : documents config keys and setup behavior
    -> src/commands/update.rs : documents reconcile semantics
    -> src/commands/status.rs : documents audit/report semantics
    -> src/commands/view.rs : documents view/setup entrypoints
